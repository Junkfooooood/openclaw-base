{
  "meta": {
    "lastTouchedVersion": "2026.3.8"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.4",
        "fallbacks": [
          "moonshot/kimi-k2.5",
          "qwen-portal/coder-model",
          "deepseek/deepseek-chat",
          "openai/gpt-5.4",
          "openai/gpt-5.3-codex"
        ]
      },
      "models": {
        "openai-codex/gpt-5.4": {},
        "openai/gpt-5.4": {
          "alias": "gpt"
        },
        "openai/gpt-5.3-codex": {},
        "moonshot/kimi-k2.5": {
          "alias": "kimi"
        },
        "qwen-portal/coder-model": {
          "alias": "qwen"
        },
        "deepseek/deepseek-chat": {
          "alias": "deepseek"
        },
        "deepseek/deepseek-reasoner": {
          "alias": "deepseek-r1"
        }
      },
      "workspace": "/ABS/PATH/TO/.openclaw/workspace-main",
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "30m",
        "activeHours": {
          "start": "08:30",
          "end": "23:00"
        },
        "session": "agent:main:feishu:direct:<FEISHU_OPEN_ID>",
        "target": "feishu",
        "to": "<FEISHU_OPEN_ID>"
      }
    },
    "list": [
      {
        "id": "main",
        "name": "YeHonglong Main",
        "workspace": "/ABS/PATH/TO/.openclaw/workspace-main",
        "agentDir": "/ABS/PATH/TO/.openclaw/agents/main/agent",
        "tools": {
          "profile": "coding",
          "allow": [
            "group:fs",
            "group:runtime",
            "group:sessions",
            "group:memory",
            "image",
            "llm-task",
            "memory-bridge",
            "obsidian-bridge",
            "policy_gate_check",
            "lobster"
          ]
        }
      },
      {
        "id": "learning",
        "name": "Learning Supervisor",
        "workspace": "/ABS/PATH/TO/.openclaw/workspace-learning",
        "agentDir": "/ABS/PATH/TO/.openclaw/agents/learning/agent",
        "model": {
          "primary": "moonshot/kimi-k2.5",
          "fallbacks": [
            "qwen-portal/coder-model",
            "deepseek/deepseek-chat",
            "openai/gpt-5.4"
          ]
        }
      },
      {
        "id": "curator",
        "name": "Knowledge Curator",
        "workspace": "/ABS/PATH/TO/.openclaw/workspace-curator",
        "agentDir": "/ABS/PATH/TO/.openclaw/agents/curator/agent",
        "model": {
          "primary": "moonshot/kimi-k2.5",
          "fallbacks": [
            "qwen-portal/coder-model",
            "deepseek/deepseek-chat",
            "openai/gpt-5.4"
          ]
        }
      },
      {
        "id": "executor",
        "name": "Task Executor",
        "workspace": "/ABS/PATH/TO/.openclaw/workspace-executor",
        "agentDir": "/ABS/PATH/TO/.openclaw/agents/executor/agent",
        "model": {
          "primary": "openai-codex/gpt-5.4",
          "fallbacks": [
            "qwen-portal/coder-model",
            "deepseek/deepseek-chat",
            "moonshot/kimi-k2.5",
            "openai/gpt-5.3-codex"
          ]
        }
      },
      {
        "id": "validator",
        "name": "Validator",
        "workspace": "/ABS/PATH/TO/.openclaw/workspace-validator",
        "agentDir": "/ABS/PATH/TO/.openclaw/agents/validator/agent",
        "model": {
          "primary": "qwen-portal/coder-model",
          "fallbacks": [
            "deepseek/deepseek-chat",
            "moonshot/kimi-k2.5",
            "openai/gpt-5.4"
          ]
        }
      }
    ]
  },
  "tools": {
    "profile": "coding",
    "web": {
      "search": {
        "enabled": true,
        "provider": "gemini",
        "gemini": {
          "apiKey": "${GEMINI_API_KEY}"
        }
      }
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory": {
          "enabled": true
        },
        "command-logger": {
          "enabled": true
        },
        "boot-md": {
          "enabled": true
        },
        "bootstrap-extra-files": {
          "enabled": true,
          "paths": [
            "workspace-main/BOOTSTRAP.md",
            "workspace-main/IDENTITY.md",
            "workspace-main/SOUL.md",
            "workspace-main/USER.md",
            "workspace-main/AGENTS.md",
            "workspace-main/MEMORY.md",
            "workspace-main/HEARTBEAT.md"
          ]
        }
      }
    }
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "appId": "${FEISHU_APP_ID}",
      "appSecret": "${FEISHU_APP_SECRET}",
      "connectionMode": "websocket",
      "domain": "feishu",
      "groupPolicy": "allowlist",
      "groupAllowFrom": [
        "oc_REPLACE_WITH_GROUP_ID"
      ]
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}",
      "allowTailscale": false
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send"
      ]
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "deepseek": {
        "baseUrl": "https://api.deepseek.com/v1",
        "apiKey": "${DEEPSEEK_API_KEY}",
        "authHeader": true,
        "api": "openai-completions",
        "models": [
          {
            "id": "deepseek-chat",
            "name": "DeepSeek Chat",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 8192
          },
          {
            "id": "deepseek-reasoner",
            "name": "DeepSeek Reasoner",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 64000
          }
        ]
      }
    }
  },
  "plugins": {
    "allow": [
      "feishu",
      "open-prose",
      "qwen-portal-auth",
      "llm-task",
      "policy-gate",
      "board-sync",
      "memory-bridge",
      "obsidian-bridge"
    ],
    "load": {
      "paths": [
        "/opt/homebrew/lib/node_modules/openclaw/extensions/feishu",
        "/ABS/PATH/TO/.openclaw/extensions"
      ]
    },
    "entries": {
      "feishu": {
        "enabled": true
      },
      "open-prose": {
        "enabled": true
      },
      "qwen-portal-auth": {
        "enabled": true
      },
      "llm-task": {
        "enabled": true,
        "config": {
          "defaultProvider": "openai-codex",
          "defaultModel": "gpt-5.4",
          "defaultAuthProfileId": "openai-codex:default"
        }
      },
      "policy-gate": {
        "enabled": true,
        "config": {
          "maxRetriesPerBranch": 3,
          "protectedPaths": [
            "/ABS/PATH/TO/.openclaw/shared/policies/Immutable_Core.md",
            "/ABS/PATH/TO/.openclaw/shared/policies/Core_Routing.md"
          ]
        }
      },
      "board-sync": {
        "enabled": true
      },
      "memory-bridge": {
        "enabled": true,
        "config": {
          "pythonBin": "/ABS/PATH/TO/mem0-venv/bin/python",
          "pythonScript": "/ABS/PATH/TO/.openclaw/shared/bridge/memory_bridge.py",
          "envFile": "/ABS/PATH/TO/agent-memory-server/.env",
          "amsBaseUrl": "http://127.0.0.1:8000",
          "defaultUserId": "lin-main",
          "defaultSessionId": "lin-main",
          "defaultNamespace": "openclaw-main",
          "autoSyncConfidence": 0.92,
          "autoSyncToSemanticGraph": false,
          "management": {
            "namespace": "openclaw-management",
            "retentionDays": 7,
            "mirrorDir": "/ABS/PATH/TO/.openclaw/shared/runtime/memory/management",
            "syncTaskTreeToWorking": true,
            "syncBranchPacketToWorking": true,
            "syncActivityToWorking": true,
            "syncSearchTraceToWorking": true,
            "syncStrategyReviewToSemanticGraph": true,
            "syncSearchTraceToSemanticGraph": false
          },
          "mem0": {
            "qdrantUrl": "http://127.0.0.1:6333",
            "collectionName": "openclaw_memory",
            "embeddingModelDims": 1536,
            "llmModel": "gpt-4.1-mini",
            "embedderModel": "text-embedding-3-small",
            "historyDbPath": "/ABS/PATH/TO/.openclaw/shared/runtime/memory/mem0_history.db",
            "neo4jUrl": "bolt://127.0.0.1:7687",
            "neo4jUsername": "neo4j",
            "neo4jDatabase": "neo4j",
            "enableGraph": true
          }
        }
      },
      "obsidian-bridge": {
        "enabled": true,
        "config": {
          "vaultRoot": "/ABS/PATH/TO/knowledge-system",
          "draftRoot": "Drafts/AI",
          "patchRoot": "Drafts/AI/_patches",
          "routes": {
            "logs": {
              "label": "日志板块",
              "draftSubdir": "Logs",
              "officialRoot": "日志板块"
            },
            "knowledge": {
              "label": "知识库",
              "draftSubdir": "Knowledge",
              "officialRoot": "_知识库"
            },
            "taskboard": {
              "label": "任务看板",
              "draftSubdir": "TaskBoard",
              "officialRoot": "任务榜单记录"
            },
            "capabilities": {
              "label": "六维能力",
              "draftSubdir": "Capabilities",
              "officialRoot": "六维能力记录"
            },
            "reputation": {
              "label": "声望",
              "draftSubdir": "Reputation",
              "officialRoot": "声望榜单"
            },
            "strategy": {
              "label": "战略板块",
              "draftSubdir": "Strategy",
              "officialRoot": "_战略板块"
            }
          },
          "allowOfficialWrites": false
        }
      }
    }
  }
}
