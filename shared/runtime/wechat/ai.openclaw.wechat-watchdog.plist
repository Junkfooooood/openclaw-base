<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.openclaw.wechat-watchdog</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/opt/node/bin/node</string>
    <string>/Users/linqingxuan/.openclaw/shared/runtime/wechat/wechat_watchdog.mjs</string>
    <string>heal</string>
    <string>--quiet</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>WorkingDirectory</key>
  <string>/Users/linqingxuan/.openclaw</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/Users/linqingxuan/.local/bin:/Users/linqingxuan/.npm-global/bin:/Users/linqingxuan/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/linqingxuan/.openclaw/shared/runtime/wechat/state/watchdog.stdout.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/linqingxuan/.openclaw/shared/runtime/wechat/state/watchdog.stderr.log</string>
</dict>
</plist>
