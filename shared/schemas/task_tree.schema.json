{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskTree",
  "type": "object",
  "required": ["task_id", "title", "mode", "branches"],
  "properties": {
    "task_id": { "type": "string" },
    "title": { "type": "string" },
    "mode": { "type": "string", "enum": ["single", "multi"] },
    "approval_mode": { "type": "string" },
    "branches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["branch_id", "owner", "goal"],
        "properties": {
          "branch_id": { "type": "string" },
          "owner": {
            "type": "string",
            "enum": ["main", "learning", "curator", "executor", "validator"]
          },
          "goal": { "type": "string" },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "expected_output": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}