{
  "id": "memory-bridge",
  "name": "Memory Bridge",
  "description": "Bridge Markdown truth memory with staged, semantic, and graph memory layers.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "markdownFiles": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "stagedDir": {
        "type": "string"
      },
      "conflictsDir": {
        "type": "string"
      },
      "commitsDir": {
        "type": "string"
      },
      "pythonBin": {
        "type": "string"
      },
      "pythonScript": {
        "type": "string"
      },
      "envFile": {
        "type": "string"
      },
      "amsBaseUrl": {
        "type": "string"
      },
      "amsAuthToken": {
        "type": "string"
      },
      "defaultUserId": {
        "type": "string"
      },
      "defaultSessionId": {
        "type": "string"
      },
      "defaultNamespace": {
        "type": "string"
      },
      "autoSyncConfidence": {
        "type": "number"
      },
      "autoSyncToSemanticGraph": {
        "type": "boolean"
      },
      "management": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "namespace": {
            "type": "string"
          },
          "retentionDays": {
            "type": "integer"
          },
          "mirrorDir": {
            "type": "string"
          },
          "syncTaskTreeToWorking": {
            "type": "boolean"
          },
          "syncBranchPacketToWorking": {
            "type": "boolean"
          },
          "syncActivityToWorking": {
            "type": "boolean"
          },
          "syncSearchTraceToWorking": {
            "type": "boolean"
          },
          "syncStrategyReviewToSemanticGraph": {
            "type": "boolean"
          },
          "syncSearchTraceToSemanticGraph": {
            "type": "boolean"
          }
        }
      },
      "mem0": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "qdrantUrl": {
            "type": "string"
          },
          "collectionName": {
            "type": "string"
          },
          "embeddingModelDims": {
            "type": "integer"
          },
          "llmModel": {
            "type": "string"
          },
          "embedderModel": {
            "type": "string"
          },
          "historyDbPath": {
            "type": "string"
          },
          "neo4jUrl": {
            "type": "string"
          },
          "neo4jUsername": {
            "type": "string"
          },
          "neo4jDatabase": {
            "type": "string"
          },
          "enableGraph": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
